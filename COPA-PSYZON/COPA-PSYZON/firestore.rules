rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tournaments collection (main state)
    match /tournaments/{document} {
      allow read: if true;
      allow write: if true; // Allows unauthenticated participants to register and update status
    }

    // Estado collection (offline-first persistence)
    match /estado/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Codes collection: authenticated admin can read/write, others can read
    match /codes/{codeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Participants collection: authenticated admin can read/write
    match /participants/{participantId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
